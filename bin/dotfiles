#!/bin/bash

# Bootstrap dotfiles on a new machine.
#
# Usage: dotfiles [THUMB_DIR]
#   THUMB_DIR   Optional path to directory containing encrypted secrets.
#               If omitted, common mount points are searched automatically.
#
# NixOS workflow:
#   1. Boot fresh NixOS install (minimal ISO is fine — gpg is pre-installed)
#   2. Plug in thumb drive
#   3. Run: sh <(curl -sSL https://raw.githubusercontent.com/albertofp/dotfiles/main/bin/dotfiles)
#      Or with explicit path: bash dotfiles /run/media/alberto/KEYS
#
# macOS workflow:
#   1. Open Terminal
#   2. Run the same curl command (or: bash dotfiles /Volumes/KEYS)
#
# Thumb drive must contain (gpg symmetric-encrypted files):
#   id_home_github.gpg    — personal GitHub SSH private key
#   hetzner.gpg           — Hetzner SSH private key
#   work_github.gpg       — work GitHub SSH private key
#   work_github.pub.gpg   — work GitHub public key
#   .zshenv.gpg           — secrets (HCLOUD_TOKEN, GITHUB_TOKEN, etc.)
#
# To encrypt files onto the thumb drive:
#   gpg --symmetric --cipher-algo AES256 -o /thumb/id_home_github.gpg  ~/.ssh/id_home_github
#   gpg --symmetric --cipher-algo AES256 -o /thumb/hetzner.gpg         ~/.ssh/hetzner
#   gpg --symmetric --cipher-algo AES256 -o /thumb/work_github.gpg     ~/.ssh/work_github
#   gpg --symmetric --cipher-algo AES256 -o /thumb/work_github.pub.gpg ~/.ssh/work_github.pub
#   gpg --symmetric --cipher-algo AES256 -o /thumb/.zshenv.gpg         ~/.zshenv

set -e

DOTFILES_DIR="$HOME/dotfiles"
DOTFILES_REPO="git@github.com:albertofp/dotfiles.git"
SSH_KEY_NAME="id_home_github"
SSH_DIR="$HOME/.ssh"

# Optional explicit thumb drive location — override via first argument
THUMB_DIR_OVERRIDE="${1:-}"

# ── Helpers ───────────────────────────────────────────────────────────────
die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "==> $*"; }

# Ensure gpg is available (it is on NixOS ISO and macOS; install via brew if needed)
ensure_gpg() {
  if command -v gpg &>/dev/null; then
    return
  fi
  if [[ "$OSTYPE" == darwin* ]]; then
    info "Installing gpg via Homebrew..."
    # Homebrew may not be installed yet — use macOS's built-in curl + a temp install
    if command -v brew &>/dev/null; then
      brew install gnupg
    else
      die "gpg not found. Install Homebrew first or install gpg manually, then retry."
    fi
  else
    # Shouldn't happen on NixOS ISO, but handle gracefully
    die "gpg not found. On NixOS it should be pre-installed on the live ISO."
  fi
}

# Decrypt a single gpg-encrypted file to a destination path
gpg_decrypt() {
  local src="$1" dst="$2"
  gpg --quiet --batch --yes --decrypt --output "$dst" "$src"
}

# ── Find thumb drive ──────────────────────────────────────────────────────
find_thumb_drive() {
  # If an explicit path was given, validate and use it directly
  if [[ -n "$THUMB_DIR_OVERRIDE" ]]; then
    [[ -d "$THUMB_DIR_OVERRIDE" ]] || die "Specified thumb drive path not found: $THUMB_DIR_OVERRIDE"
    echo "$THUMB_DIR_OVERRIDE"
    return
  fi

  local candidates=()

  if [[ "$OSTYPE" == darwin* ]]; then
    while IFS= read -r vol; do
      [[ -f "$vol/$SSH_KEY_NAME.gpg" ]] && candidates+=("$vol")
    done < <(find /Volumes -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
  else
    for mp in /media /mnt /run/media/"$USER"; do
      [[ -d "$mp" ]] || continue
      while IFS= read -r vol; do
        [[ -f "$vol/$SSH_KEY_NAME.gpg" ]] && candidates+=("$vol")
      done < <(find "$mp" -mindepth 1 -maxdepth 2 -type d 2>/dev/null)
    done
  fi

  case "${#candidates[@]}" in
    0) return 1 ;;
    1) echo "${candidates[0]}" ;;
    *) echo "Multiple thumb drives found. Enter the number to use:" >&2
       select vol in "${candidates[@]}"; do echo "$vol"; break; done ;;
  esac
}

# ── Decrypt and install SSH keys from thumb drive ─────────────────────────
copy_ssh_from_thumb() {
  local thumb="$1"

  info "Decrypting files from thumb drive (you will be prompted for your passphrase)..."
  mkdir -p "$SSH_DIR"
  chmod 700 "$SSH_DIR"

  local found=0
  while IFS= read -r src; do
    local filename
    filename=$(basename "$src" .gpg)
    local dst

    # .zshenv goes to $HOME, everything else to $SSH_DIR
    if [[ "$filename" == ".zshenv" ]]; then
      dst="$HOME/$filename"
    else
      dst="$SSH_DIR/$filename"
    fi

    if [[ -f "$dst" ]]; then
      echo "  SKIP (already exists): $filename"
      continue
    fi

    gpg_decrypt "$src" "$dst"
    # Private keys: 600; public keys and .zshenv: 600; .pub: 644
    if [[ "$filename" == *.pub ]]; then
      chmod 644 "$dst"
    else
      chmod 600 "$dst"
    fi
    echo "  decrypted: $filename"
    found=1
  done < <(find "$thumb" -maxdepth 1 -name "*.gpg" 2>/dev/null | sort)

  [[ $found -eq 0 ]] && echo "  WARNING: no .gpg files found on thumb drive."
}

# ── Ensure SSH key + secrets are present (from disk or thumb drive) ───────
setup_from_thumb() {
  mkdir -p "$SSH_DIR"
  chmod 700 "$SSH_DIR"

  local needs_thumb=0
  [[ ! -f "$SSH_DIR/$SSH_KEY_NAME" ]] && needs_thumb=1
  [[ ! -f "$HOME/.zshenv" ]]          && needs_thumb=1

  if [[ $needs_thumb -eq 1 ]]; then
    info "Some files missing — looking for thumb drive..."
    local thumb
    if thumb=$(find_thumb_drive); then
      info "Found thumb drive: $thumb"
      ensure_gpg
      copy_ssh_from_thumb "$thumb"
    else
      die "Required files missing and no thumb drive detected. Plug in the thumb drive and retry."
    fi
  else
    info "SSH key and .zshenv already present — skipping thumb drive."
  fi

  # Start agent and load key for this session
  eval "$(ssh-agent -s)" > /dev/null
  ssh-add "$SSH_DIR/$SSH_KEY_NAME"
}

# ── Clone dotfiles ─────────────────────────────────────────────────────────
clone_dotfiles() {
  if [[ -d "$DOTFILES_DIR/.git" ]]; then
    info "Dotfiles already cloned, pulling latest..."
    git -C "$DOTFILES_DIR" pull
  else
    info "Cloning dotfiles..."
    ssh-keyscan github.com >> "$SSH_DIR/known_hosts" 2>/dev/null
    git clone "$DOTFILES_REPO" "$DOTFILES_DIR"
  fi
}

# ═══════════════════════════════════════════════════════════════════════════
# Main
# ═══════════════════════════════════════════════════════════════════════════

setup_from_thumb

case "$OSTYPE" in
  # ── NixOS ───────────────────────────────────────────────────────────────
  linux-gnu*)
    # Nix is pre-installed on NixOS. On other Linux, install it.
    if ! command -v nix &>/dev/null; then
      info "Installing Nix..."
      curl -sSL https://nixos.org/nix/install | sh -s -- --daemon
      # shellcheck disable=SC1091
      . /etc/profile.d/nix.sh
    fi

    if ! command -v git &>/dev/null; then
      nix-env -iA nixpkgs.git
    fi

    clone_dotfiles

    # Copy public key into the expected location so system.nix can reference it
    mkdir -p "$DOTFILES_DIR/ssh"
    cp "$SSH_DIR/$SSH_KEY_NAME.pub" "$DOTFILES_DIR/ssh/$SSH_KEY_NAME.pub"

    info "Applying NixOS configuration (system + home-manager)..."
    if [[ ! -f "$DOTFILES_DIR/nix/hardware.nix" ]]; then
      info "Generating hardware configuration..."
      sudo nixos-generate-config --show-hardware-config > "$DOTFILES_DIR/nix/hardware.nix"
    fi

    sudo nixos-rebuild switch --flake "$DOTFILES_DIR/nix#alberto"

    info "Setting passwords (you will be prompted)..."
    echo "Set your user password:"
    passwd
    echo "Set the root password:"
    sudo passwd root
    ;;

  # ── macOS ───────────────────────────────────────────────────────────────
  darwin*)
    if ! command -v brew &>/dev/null; then
      info "Installing Homebrew..."
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    if ! command -v ansible &>/dev/null; then
      brew install ansible
    fi

    clone_dotfiles

    if [[ -f "$HOME/.ansible_vault_pass.txt" ]]; then
      ansible-playbook \
        -i 'localhost,' \
        -c local "$DOTFILES_DIR/ansible/playbooks/bootstrap.yaml" \
        --vault-password-file "$HOME/.ansible_vault_pass.txt"
    else
      info "No .ansible_vault_pass.txt found, prompting for vault password..."
      ansible-playbook \
        -i 'localhost,' \
        -c local "$DOTFILES_DIR/ansible/playbooks/bootstrap.yaml" \
        --ask-vault-password
    fi
    ;;

  *)
    die "OS not supported: $OSTYPE"
    ;;
esac

info "Bootstrap complete."
