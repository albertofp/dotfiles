#!/bin/bash

set -e

DOTFILES_DIR=$HOME/dotfiles

case "$OSTYPE" in
  linux-gnu*)
    # Install Nix if not present (handles both NixOS and other Linux)
    if ! command -v nix &>/dev/null; then
      echo "Installing Nix..."
      curl -sSL https://nixos.org/nix/install | sh -s -- --daemon
      # shellcheck disable=SC1091
      . /etc/profile.d/nix.sh
    fi

    if ! command -v git &>/dev/null; then
      nix-env -iA nixpkgs.git
    fi

    if [ ! -d "$DOTFILES_DIR" ]; then
      git clone https://github.com/albertofp/dotfiles "$DOTFILES_DIR"
    fi

    echo "Running home-manager switch..."
    nix run home-manager -- switch --flake "$DOTFILES_DIR/nix#alberto"
    ;;

  darwin*)
    if ! command -v brew &>/dev/null; then
      echo "Installing Homebrew..."
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    if ! command -v ansible &>/dev/null; then
      brew install ansible
    fi

    if [ ! -d "$DOTFILES_DIR" ]; then
      git clone https://github.com/albertofp/dotfiles "$DOTFILES_DIR"
    fi

    if [[ -f $HOME/.ansible_vault_pass.txt ]]; then
      ansible-playbook \
        -i 'localhost,' \
        -c local "$DOTFILES_DIR"/ansible/playbooks/bootstrap.yaml \
        --vault-password-file "$HOME"/.ansible_vault_pass.txt
    else
      echo "No .ansible_vault_pass.txt found, prompting for vault password..."
      ansible-playbook \
        -i 'localhost,' \
        -c local "$DOTFILES_DIR"/ansible/playbooks/bootstrap.yaml \
        --ask-vault-password
    fi
    ;;

  *)
    echo "OS not supported: $OSTYPE"
    exit 1
    ;;
esac
