[user]
	email = albertopluecker@gmail.com
	name = Alberto Fontenelle Pluecker
[includeIf "hasconfig:remote.*.url:https://github.je-labs.com/**"]
	path = ~/.gitconfig-jet
[includeIf "hasconfig:remote.*.url:git@github.je-labs.com:*/**"]
	path = ~/.gitconfig-jet
[push]
	autoSetupRemote = true
[alias]
	fp = !sh -c 'git fetch && git pull origin $(git symbolic-ref refs/remotes/origin/HEAD | sed "s@^refs/remotes/origin/@@")'
	uncommit = reset --soft HEAD^
	unstage = restore --staged
	sl = stash list
	spo= stash pop
	spu= stash push
	sd = stash drop
	cp = cherry-pick
[url "git@github.com:"]
	insteadOf = https://github.com/
[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
[pull]
	rebase = true
[core]
	attributesfile = /Users/alberto.pluecker/.gitattributes
	excludesFile = /Users/alberto.pluecker/.gitignore
[rerere]
	enabled = true
; for issues with go mod tidy and private modules
; also comment out lines 10-13
; [url "https://github.com/"]
; 	insteadOf = git@github.com:
; [url "https://jus.tw.cx/"]
; 	insteadOf = git@jus.tw.cx:
[branch]
	sort = -committerdate
