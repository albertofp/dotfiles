{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "question": "allow",
    "webfetch": "allow",
    "external_directory": {
      "~/**": "allow"
    },
    "bash": {
      "*": "ask",
      "grep *": "allow",
      "ls *": "allow",
      "ls": "allow",
      "cat *": "allow",
      "find *": "allow",
      "head *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "echo *": "allow",
      "env": "allow",
      "python3 *": "allow",
      "pip3 *": "allow",
      "curl *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "git status": "allow",
